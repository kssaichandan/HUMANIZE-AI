# Everything internal — docs, session logs, tests, screenshots — lives in doc/.
# It is kept local and never published. Put anything private in doc/.
doc/

# API keys — safety net (these live in the project root, not in doc/).
# Never commit these.
.groq_key
.openai_key
.anthropic_key
.gemini_key

# Tool / editor config
.claude/
.vscode/

# Stray test artifacts, in case any tool regenerates them in the project root
test_*
*.log
*.swp
*.swo

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
